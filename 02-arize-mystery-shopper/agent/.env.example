# Voice-AI Mystery Shopper — environment variables
# Copy this file to .env and fill in the values. Do not commit .env.

# --- Google Cloud / Vertex AI ----------------------------------------------

# GCP project that hosts Vertex AI access. Created during hackathon setup.
GOOGLE_CLOUD_PROJECT=

# Vertex AI region. us-central1 is the default for Agent Builder + Gemini 3.
GOOGLE_CLOUD_REGION=us-central1

# Gemini 3 model id used for both the "customer" role and the judge.
# Override per-call from code if you want to A/B different models.
# TODO: confirm the exact model id once Gemini 3 GA naming is locked.
GEMINI_MODEL_ID=gemini-3.0-pro

# Path to a service-account JSON key. Only set this when running outside
# Cloud Run; on Cloud Run we rely on the attached service account.
GOOGLE_APPLICATION_CREDENTIALS=

# --- Arize Phoenix ----------------------------------------------------------

# Phoenix collector endpoint. For Phoenix Cloud this is something like
# https://app.phoenix.arize.com; for a self-hosted instance, the OTel endpoint.
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com

# Phoenix API key. Required for Phoenix Cloud; optional for local Phoenix.
PHOENIX_API_KEY=

# Phoenix project name. All traces and experiments are written under this
# project so the demo report can be filtered cleanly in the Phoenix UI.
PHOENIX_PROJECT_NAME=mystery-shopper

# Phoenix dataset id for the canonical 50-scenario test suite. Populated by
# scripts/seed_dataset.py the first time we run a real audit; until then,
# scenarios.py is the source of truth.
PHOENIX_SCENARIO_DATASET_ID=

# --- Phoenix MCP server -----------------------------------------------------

# Command used to start the Phoenix MCP server. The Python MCP client spawns
# this as a subprocess and speaks stdio with it. Default assumes npx is on
# PATH; in Cloud Run we'll bake the package into the image.
PHOENIX_MCP_COMMAND=npx
PHOENIX_MCP_ARGS=-y,@arizeai/phoenix-mcp

# --- Audit runtime ----------------------------------------------------------

# Hard cap on concurrent conversations against a single target. Protects
# us from looking like a DDoS to the target AI. 1 = strictly serial.
AUDIT_MAX_CONCURRENCY_PER_TARGET=1

# Wall-clock cap (seconds) per scenario run. Aborts runaway dialogs.
AUDIT_SCENARIO_TIMEOUT_S=120

# Maximum dialog turns before we force-stop a scenario.
AUDIT_MAX_TURNS=12

# --- App ------------------------------------------------------------------

# Port FastAPI binds to. Cloud Run injects PORT; leave 8080 for local.
PORT=8080

# "development" enables verbose logging and disables the launch banner.
APP_ENV=development
