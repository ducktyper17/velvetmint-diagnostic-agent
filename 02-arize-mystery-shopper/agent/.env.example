# Self-Improving QA Agent — environment variables
# Copy this file to .env and fill in the values. .env is gitignored.

# ============================================================================
# Google Cloud / Vertex AI (Gemini via google-genai SDK)
# ============================================================================

# Use Vertex AI as the Gemini backend (recommended for the hackathon — uses
# Application Default Credentials + GCP project rather than a raw API key).
GOOGLE_GENAI_USE_VERTEXAI=1

# GCP project hosting Vertex AI access. Required when GOOGLE_GENAI_USE_VERTEXAI=1.
GOOGLE_CLOUD_PROJECT=

# Region for Vertex AI. us-central1 is the default for Agent Platform.
GOOGLE_CLOUD_LOCATION=us-central1

# Path to a service-account JSON key. Only set this when running outside
# Cloud Run; on Cloud Run we rely on the attached service account.
GOOGLE_APPLICATION_CREDENTIALS=

# (Alternative path) If you don't have Vertex AI access yet, set GOOGLE_API_KEY
# and comment out the GOOGLE_GENAI_USE_VERTEXAI line above. The hackathon
# allows either path.
# GOOGLE_API_KEY=

# Gemini model ids. We use 2.5 Pro for the QA brain and 2.5 Flash for the SUT
# so the SUT is cheap to run 100x per audit cycle.
QA_MODEL=gemini-2.5-pro
SUT_MODEL=gemini-2.5-flash

# ============================================================================
# Arize Phoenix Cloud (tracing + datasets + experiments + prompts)
# ============================================================================

# Phoenix API key. Create at app.phoenix.arize.com → Settings → API Keys.
# May be px_live_... OR a JWT Bearer token (both work as PHOENIX_API_KEY).
# NOT an Arize AX key — they are different products.
PHOENIX_API_KEY=

# Optional: same auth for generic OTEL exporters (Phoenix SDK prefers PHOENIX_API_KEY).
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <your-key>

# REQUIRED for Phoenix Cloud: copy the full Hostname from Phoenix → Settings.
# Must include the /s/<your-space> path; bare app.phoenix.arize.com 401s OTLP.
# Example: https://app.phoenix.arize.com/s/my-team-space
PHOENIX_COLLECTOR_ENDPOINT=

# Phoenix project name. Both the QA agent and the SUT trace into this project
# so cross-agent sessions are inspectable side-by-side.
PHOENIX_PROJECT_NAME=self-improving-qa-agent

# Phoenix dataset name for the scenario suite. The scripts/seed_phoenix.py
# script creates this if it doesn't exist and populates the 50-scenario set.
PHOENIX_SCENARIO_DATASET_NAME=velvetmint-support.scenarios

# Phoenix prompt name for the SUT's system instruction. The QA agent rewrites
# this via upsert-prompt during the self-improvement loop.
PHOENIX_SUT_PROMPT_NAME=sut-velvetmint-support

# ============================================================================
# Phoenix MCP server (the agent's runtime hands into Phoenix)
# ============================================================================

# We run @arizeai/phoenix-mcp via npx, mounted into ADK as an McpToolset.
# Node 18+ must be on PATH. In Cloud Run we'll bake npx into the image.
PHOENIX_MCP_COMMAND=npx
PHOENIX_MCP_ARGS=-y,@arizeai/phoenix-mcp@latest

# ============================================================================
# Audit runtime
# ============================================================================

# Hard cap on concurrent scenario runs (the SUT is rate-limited by us, not
# by an external party, so we can go higher than the original Mystery Shopper
# design assumed).
AUDIT_MAX_CONCURRENCY=4

# Wall-clock cap (seconds) per scenario run. Aborts runaway dialogs.
AUDIT_SCENARIO_TIMEOUT_S=120

# Maximum dialog turns before we force-stop a scenario.
AUDIT_MAX_TURNS=8

# Number of judge replicas per (scenario, dimension) pair. Median + IQR is
# reported. 3 is the right balance of variance estimation vs. cost.
AUDIT_JUDGE_REPLICAS=3

# ============================================================================
# App
# ============================================================================

# Port FastAPI binds to. Cloud Run injects PORT; leave 8080 for local.
PORT=8080

# "development" enables verbose logging and disables the launch banner.
APP_ENV=development
