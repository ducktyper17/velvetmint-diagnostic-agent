# =============================================================================
# Agent Reliability Guard - example environment
#
# Copy to `.env` and fill in. Do not commit a real `.env`.
# =============================================================================

# ----- Service / runtime -----------------------------------------------------

PORT=8080
LOG_LEVEL=INFO

# local | dev | demo | prod
ENVIRONMENT=local

AGENT_MAX_ITERATIONS=12


# ----- Google Cloud / Vertex AI / Agent Platform -----------------------------

GOOGLE_CLOUD_PROJECT=rapid-agent-hack-2026
GOOGLE_CLOUD_LOCATION=us-central1

# Leave empty when using ADC.
GOOGLE_APPLICATION_CREDENTIALS=

# Keep this Google-hosted only. No non-Google models allowed for the hackathon.
VERTEX_MODEL=gemini-2.5-pro

# Dev-only switch to keep tests/offline work deterministic.
STUB_GEMINI_RESPONSES=false


# ----- Dynatrace -------------------------------------------------------------

# Your Dynatrace tenant URL, for example:
# https://abc12345.apps.dynatrace.com
DYNATRACE_ENVIRONMENT_URL=https://replace-me.apps.dynatrace.com

# Remote Dynatrace MCP gateway (recommended for the hackathon):
# https://YOUR_ENV.apps.dynatrace.com/platform-reserved/mcp-gateway/v0.1/servers/dynatrace-mcp/mcp
#
# Local HTTP mode alternative:
# npx -y @dynatrace-oss/dynatrace-mcp-server@latest --http --port 3333
# DYNATRACE_MCP_URL=http://127.0.0.1:3333
DYNATRACE_MCP_URL=https://replace-me.apps.dynatrace.com/platform-reserved/mcp-gateway/v0.1/servers/dynatrace-mcp/mcp

# Platform token with mcp-gateway:servers:invoke + storage scopes.
# Map from 00-shared/SECRET-MAP.md: hackathon-dynatrace-api-token
DYNATRACE_MCP_TOKEN=replace-me-with-platform-token

# Optional notebook naming and alerting defaults.
DYNATRACE_DEFAULT_NOTEBOOK_NAME=agent-reliability-guard
DYNATRACE_NOTIFICATION_CHANNEL=#ai-platform-alerts

# Default lookback window for investigations.
LOOKBACK_MINUTES_DEFAULT=120

# Analyzer names may differ per tenant; these match the public Dynatrace docs.
DYNATRACE_CHANGE_ANALYZER_NAME=Changepoint Agent
DYNATRACE_FORECAST_ANALYZER_NAME=Forecasting Agent

# Dev-only switch for offline testing without a live Dynatrace tenant.
STUB_DYNATRACE_TOOLS=false


# ----- Demo mode -------------------------------------------------------------

DEMO_MODE=false
DEMO_SERVICE_NAME=refund-assistant
DEMO_RELEASE_ID=release-2026-05-26-bad-prompt
