# Refund Assistant demo — copy to .env

PORT=8090
LOG_LEVEL=INFO

# healthy | bad
PROMPT_MODE=healthy
RELEASE_ID=release-2026-05-26-baseline
PROMPT_VERSION=v11

# Gemini on Vertex AI only (hackathon rule)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash

# When true, skip Gemini and return deterministic text (local UI tests).
STUB_GEMINI=false

# ----- OpenTelemetry → Dynatrace -----
# See https://docs.dynatrace.com/docs/ingest-from/opentelemetry
OTEL_SERVICE_NAME=refund-assistant
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Example (replace env id and token):
# OTEL_EXPORTER_OTLP_ENDPOINT=https://YOUR_ENV.live.dynatrace.com/api/v2/otlp
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Api-Token%20dt0c01.XXXX
