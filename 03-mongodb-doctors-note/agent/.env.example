# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.
# Cloud Run will pull these from Secret Manager in production; this file
# is for local development only.

# --- MongoDB Atlas ---------------------------------------------------------
# The full SRV connection string from Atlas. Must include the username,
# password (or X.509 reference), and the cluster host. The application
# always uses a single database, named below.
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=doctors_note

# The collections we read/write. Override only if you intentionally
# partition them (e.g. per-environment).
MONGODB_COLLECTION_LITERATURE=literature
MONGODB_COLLECTION_GUIDELINES=guidelines
MONGODB_COLLECTION_FORUM=forum_posts
MONGODB_COLLECTION_VAULT=user_vault

# --- MongoDB MCP server ----------------------------------------------------
# How the FastAPI service launches the MongoDB MCP server as a subprocess.
# Default uses the official npm-distributed server over stdio. Cloud Run
# image bundles this binary; for local dev you need Node.js 20+ installed
# and the package available on PATH (e.g. via `npx`).
#
# See https://www.mongodb.com/docs/mcp-server/ for full options.
MCP_SERVER_CMD=npx
MCP_SERVER_ARGS=-y mongodb-mcp-server --connection-string ${MONGODB_URI}

# --- Google Cloud / Vertex AI ----------------------------------------------
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Path to a service-account JSON for local dev. On Cloud Run, the
# attached service account is used automatically and this is unset.
GOOGLE_APPLICATION_CREDENTIALS=

# Which Gemini model to use for extraction and synthesis.
GEMINI_MODEL=gemini-2.5-pro

# Vertex-hosted embedding model used for Atlas Vector Search. Keep
# VERTEX_EMBEDDING_DIM aligned with the Atlas Vector Search index.
VERTEX_EMBEDDING_MODEL=gemini-embedding-001
VERTEX_EMBEDDING_DIM=3072

# --- Service runtime -------------------------------------------------------
# Static demo token gating the /vault/save endpoint. The backup scaffold
# does not ship real auth; production would replace this with OIDC.
DEMO_VAULT_TOKEN=change-me-before-demo

# Optional. If set, the service will refuse to start when the disclaimer
# file is missing or empty. Recommended ON in any deployed environment.
REQUIRE_DISCLAIMER_FILE=1

# Uvicorn / Cloud Run port. Cloud Run injects PORT itself.
PORT=8080
