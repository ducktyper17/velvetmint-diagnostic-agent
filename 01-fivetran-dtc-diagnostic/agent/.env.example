# =============================================================================
# DTC Diagnostic Agent — example environment
#
# Copy to `.env` and fill in. The agent reads these via `agent.config.Settings`
# (Pydantic BaseSettings). All keys are documented; defaults shown where
# applicable.
#
# DO NOT commit a real .env file.
# =============================================================================


# ----- Service / runtime -----------------------------------------------------

# Cloud Run / local port. Cloud Run injects $PORT; locally we default to 8080.
PORT=8080

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Where the agent thinks it is running. Affects logging, metrics, demo flags.
# Values: local | dev | demo | prod
ENVIRONMENT=local

# Hard cap on agent loop iterations per /diagnose call.
AGENT_MAX_ITERATIONS=25


# ----- Google Cloud / Vertex AI / Gemini 3 -----------------------------------

# GCP project hosting Vertex AI, Cloud Run, Secret Manager, and BigQuery.
GOOGLE_CLOUD_PROJECT=rapid-agent-hack-2026

# Region. us-central1 has the broadest Gemini 3 availability and lowest cost.
GOOGLE_CLOUD_LOCATION=us-central1

# Optional path to a service-account key file when running locally.
# Recommended local setup is ADC instead:
#   export CLOUDSDK_CONFIG="$HOME/.local/share/gcloud-config"
#   export PATH="$HOME/google-cloud-sdk/bin:$PATH"
#   gcloud auth application-default login
# Leave this empty when using ADC.
GOOGLE_APPLICATION_CREDENTIALS=

# Gemini model name as exposed in Vertex AI Model Garden.
# Verified working on this account (May 26): gemini-2.5-pro.
# Swap to gemini-3.0-pro once Gemini 3 is GA in Model Garden.
VERTEX_MODEL=gemini-2.5-pro


# ----- BigQuery (Fivetran's destination) -------------------------------------

# Dataset where Fivetran lands raw synced rows. We point our diagnostic queries
# here. Must already exist (Fivetran creates it on first sync).
BIGQUERY_DATASET=fivetran_velvetmint

# Optional: location of the dataset. If empty, BigQuery client uses the
# project's default. Match it to GOOGLE_CLOUD_LOCATION when possible.
BIGQUERY_LOCATION=us-central1


# ----- Fivetran MCP server ---------------------------------------------------

# Base URL of the Fivetran MCP server (https://github.com/fivetran/fivetran-mcp).
# In Cloud Run we run it as a separate service; locally we run it on :3333.
FIVETRAN_MCP_URL=http://localhost:3333

# Bearer token the agent passes when calling the MCP server. The MCP server
# itself reads FIVETRAN_API_KEY/SECRET from its own env — we do NOT expose
# Fivetran credentials directly to the agent.
FIVETRAN_MCP_TOKEN=replace-me-with-a-strong-random-token

# When true, the agent is allowed to call write-mode tools (create_connection,
# sync_connection, modify_connection_schema_config, ...). The MCP server also
# enforces this server-side via its own FIVETRAN_ALLOW_WRITES flag.
FIVETRAN_ALLOW_WRITES=true

# Local-dev only: raw Fivetran API credentials used by the official stdio MCP
# server when we run it inside the app process. In Cloud Run we can move these
# to Secret Manager and launch a dedicated MCP service instead.
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=

# Local path to the official Fivetran MCP `server.py` file.
FIVETRAN_MCP_SERVER_PATH=/absolute/path/to/fivetran-mcp/server.py

# Group and destination ids discovered from the Fivetran account.
# In early local prototyping these may be the same id; for the real demo they
# should point at the group that owns your BigQuery destination.
FIVETRAN_GROUP_ID=
FIVETRAN_DESTINATION_ID=


# ----- MongoDB Atlas ---------------------------------------------------------

# Standard SRV connection string from Atlas.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true

# Database name to use within the cluster.
MONGODB_DB=dtc_diagnostic


# ----- Demo mode flags -------------------------------------------------------

# When DEMO_MODE=true, the agent uses pre-warmed Fivetran connections and a
# seeded BigQuery dataset to keep the 3-minute video on rails. See
# SCAFFOLD-NOTES.md for what changes when this flag flips.
DEMO_MODE=false

# Optional: ID of the brand to diagnose. In production this comes from the
# request body; in DEMO_MODE it defaults to "velvetmint".
DEMO_BRAND_ID=velvetmint
