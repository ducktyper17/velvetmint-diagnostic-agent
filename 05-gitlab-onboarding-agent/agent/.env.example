PORT=8080
LOG_LEVEL=INFO
ENVIRONMENT=local

# Demo mode uses the bundled service catalog and simulated GitLab actions.
# Set to false once GitLab MCP OAuth and write access are configured.
DEMO_MODE=true

# Gemini executive summary at the end of each incident run.
USE_GEMINI_SUMMARY=true
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=REPLACE_ME_GCP_PROJECT
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-pro

# GitLab MCP (official server, HTTP transport)
GITLAB_BASE_URL=https://gitlab.com
GITLAB_GROUP_PATH=rapid-agent-labs
GITLAB_MCP_URL=https://gitlab.com/api/v4/mcp
GITLAB_MCP_TOKEN=REPLACE_ME_GITLAB_TOKEN
GITLAB_ALLOW_WRITES=true

# Blast-radius policy
AUTO_DEPLOY_MAX_RISK=74
DEMO_CLOUD_RUN_REGION=us-central1
