# =============================================================================
# Elastic Apartment Detective - example environment
# Copy to `.env` for local development. Do not commit real secrets.
# =============================================================================

# ----- Service / runtime -----------------------------------------------------
PORT=8080
LOG_LEVEL=INFO
ENVIRONMENT=local
AGENT_MAX_ITERATIONS=10

# ----- Google Cloud / Gemini -------------------------------------------------
GOOGLE_CLOUD_PROJECT=rapid-agent-hack-2026
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_MODEL=gemini-2.5-pro

# ----- Elastic MCP -----------------------------------------------------------
# Full Elastic Agent Builder MCP URL from Kibana's "Manage MCP" UI.
ELASTIC_MCP_URL=http://localhost:3000/api/agent_builder/mcp
ELASTIC_MCP_API_KEY=replace-me-with-elastic-api-key

# ----- Investigation defaults ------------------------------------------------
DEMO_MODE=true
DEFAULT_CITY=New York
DEFAULT_STATE=NY
DEFAULT_ZIP=10002

# ----- Demo listing ----------------------------------------------------------
DEMO_LISTING_URL=https://streeteasy.example/listing/123-orchard-st-new-york-ny-10002
DEMO_ADDRESS=123 Orchard St, New York, NY 10002
